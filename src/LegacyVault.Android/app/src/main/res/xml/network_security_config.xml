<?xml version="1.0" encoding="utf-8"?>
<!--
    RELEASE: cleartext disabled, system CAs only.
    For self-hosted users with valid HTTPS certs, no changes needed.
    Users with self-signed certs must install their CA via device Settings.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
