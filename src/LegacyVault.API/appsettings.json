{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/legacyvault.db"
  },
  "JwtSettings": {
    "Secret": "CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET_IN_ENV_OR_SECRETS",
    "Issuer": "LegacyVault",
    "Audience": "LegacyVaultClients",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "30"
  }
}
