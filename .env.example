# Copy this file to .env and fill in the values
# NEVER commit .env to source control

# Required: at least 64 characters, random
JWT_SECRET=replace-this-with-a-long-random-string-at-least-64-characters-long-here!!

# Path on the HOST machine where uploaded images are stored.
# Using a folder outside Docker prevents storage space limitations.
# Run: pwsh ./setup-env.ps1   (auto-detects OS and fills these in)
# Windows:   VAULT_UPLOADS_PATH=C:/Users/YourName/Documents/.vault/uploads
# Mac/Linux: VAULT_UPLOADS_PATH=/Users/yourname/Documents/.vault/uploads
VAULT_UPLOADS_PATH=

# Path on the HOST machine where database backups are stored.
# Run: pwsh ./setup-env.ps1   (auto-detects OS and fills these in)
# Windows:   VAULT_BACKUPS_PATH=C:/Users/YourName/Documents/.vault/backups
# Mac/Linux: VAULT_BACKUPS_PATH=/Users/yourname/Documents/.vault/backups
VAULT_BACKUPS_PATH=

# Host port the API is exposed on during development (Swagger access).
# Change this if port 5000 is already in use on your machine.
# Mac/Linux default: 5000  |  set to e.g. 5500 if 5000 is taken
API_PORT=5000
